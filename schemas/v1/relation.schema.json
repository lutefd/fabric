{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabric.local/schemas/v1/relation.schema.json",
  "title": "Fabric Relation",
  "type": "object",
  "required": ["relation_id", "type", "from", "to", "created_at"],
  "$defs": {
    "node": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "id": {"type": "string", "minLength": 1},
        "provider": {"type": "string"},
        "url": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "relation_id": {"type": "string", "pattern": "^rel_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "type": {"enum": ["derived_from", "informed_by", "implements", "supersedes", "challenges", "resolves", "delivered_to", "exposed_to"]},
    "from": {"$ref": "#/$defs/node"},
    "to": {"$ref": "#/$defs/node"},
    "created_at": {"type": "string", "format": "date-time"},
    "reason": {"type": "string"}
  },
  "additionalProperties": false
}
